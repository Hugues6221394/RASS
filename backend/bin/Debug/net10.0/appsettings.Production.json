{
  "ConnectionStrings": {
    "Default": "Host=production-db-host;Port=5432;Database=rass_prod_db;Username=${DB_USER};Password=${DB_PASSWORD}"
  },
  "Jwt": {
    "Issuer": "rass.rw",
    "Audience": "rass.clients",
    "SigningKey": "${JWT_SIGNING_KEY}",
    "ExpiryMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "InternalService": {
    "AIInsightsKey": "${AIINSIGHTS_INTERNAL_KEY}"
  },
  "AI": {
    "LLM": {
      "Endpoint": "https://api.groq.com/openai/v1/chat/completions",
      "Model": "openai/gpt-oss-120b",
      "FallbackModels": "llama-3.3-70b-versatile,openai/gpt-oss-20b",
      "ApiKeyHeader": "${LLM_APIKEY_HEADER}",
      "RawApiKeyHeader": false,
      "ApiKey": "${LLM_API_KEY}",
      "Temperature": 0.2
    }
  },
  "MtnMomo": {
    "SubscriptionKey": "${MTN_MOMO_SUBSCRIPTION_KEY}",
    "ApiUser": "${MTN_MOMO_API_USER}",
    "ApiKey": "${MTN_MOMO_API_KEY}",
    "BaseUrl": "https://proxy.momoapi.mtn.com",
    "Environment": "${MTN_MOMO_ENVIRONMENT}"
  },
  "AllowedHosts": "api.rass.rw"
}
